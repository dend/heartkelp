  <name>Heartkelp</name>
  <summary>Wayland screen-to-GIF recorder</summary>

  <description>
    <p>A lightweight screen recorder that captures your Wayland desktop and saves it as an animated GIF.</p>
    <ul>
      <li>Record specific screen regions or your full display</li>
      <li>Trim recordings before saving</li>
      <li>Configurable frame rate and output directory</li>
    </ul>
  </description>

  <launchable type="desktop-id">heartkelp.desktop</launchable>

  <url type="homepage">https://github.com/dend/heartkelp</url>
  <url type="bugtracker">https://github.com/dend/heartkelp/issues</url>
  <url type="vcs-browser">https://github.com/dend/heartkelp</url>

